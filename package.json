{
  "dependencies": {
    "dotenv": "^17.2.3",
    "mongoose": "^9.0.1"
  },
  "scripts": {
    "build": "npm --prefix server install && npm --prefix next-app install --include=dev && npm --prefix next-app run build",
    "start": "npm-run-all --parallel start:server start:next",
    "start:server": "npm --prefix server start",
    "start:next": "npm --prefix next-app start",
    "dev": "npm-run-all --parallel dev:server dev:next",
    "dev:server": "cd server && npm run dev",
    "dev:next": "cd next-app && npm run dev"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
